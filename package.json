{
  "name": "end-of-quarter-countdown",
  "version": "2.4.2",
  "description": "End of Quarter Countdown — Windows edition",
  "main": "main.js",
  "author": "Ian Hawkins <ian@hawkinsmultimedia.net>",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "au.com.hawkinsmultimedia.endofquartercountdown",
    "productName": "End of Quarter Countdown",
    "copyright": "Copyright © 2025 Ian Hawkins",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signtoolOptions": null
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "End of Quarter Countdown"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
